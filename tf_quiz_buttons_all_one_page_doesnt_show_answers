<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>True or False Quiz</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 20px;
    }
    .question {
      margin: 20px 0;
    }
    button {
      margin: 5px;
      padding: 10px 20px;
      cursor: pointer;
    }
    #result {
      font-size: 20px;
      margin-top: 20px;
      font-weight: bold;
    }
  </style>
</head>
<body>

  <h1>True or False Quiz</h1>

  <div id="quiz"></div>

  <button onclick="submitQuiz()">Submit</button>

  <div id="result"></div>

  <script>
    const questions = [
      { text: "The Earth is flat.", answer: false },
      { text: "JavaScript is a programming language.", answer: true },
      { text: "The sun rises in the west.", answer: false },
      { text: "Water boils at 100°C.", answer: true },
      { text: "Humans can breathe underwater without equipment.", answer: false }
    ];

    const userAnswers = new Array(questions.length).fill(null);

    const quizDiv = document.getElementById("quiz");

    questions.forEach((q, index) => {
      const div = document.createElement("div");
      div.className = "question";

      div.innerHTML = `
        <p>${index + 1}. ${q.text}</p>
        <button onclick="answer(${index}, true)">True</button>
        <button onclick="answer(${index}, false)">False</button>
        <span id="status-${index}"></span>
      `;

      quizDiv.appendChild(div);
    });

    function answer(index, value) {
      userAnswers[index] = value;
      document.getElementById(`status-${index}`).textContent = "Answered";
    }

    function submitQuiz() {
      let score = 0;

      questions.forEach((q, i) => {
        if (userAnswers[i] === q.answer) {
          score++;
        }
      });

      document.getElementById("result").textContent =
        `You scored ${score} out of ${questions.length}`;
    }
  </script>

</body>
</html>
