  }//end of q4
    
];//end of const questions = 

let currentQuestion = 0;
let userAnswers = new Array(questions.length).fill(null);
let timeLeft = 180;
let timerInterval;
let quizSubmitted = false;

function startTimer() 
{//beginning of function startTimer() 
    
  timerInterval = setInterval(() => 
    {//beginning of timerInterval = setInterval(() => 
        
    timeLeft--;

    let minutes = Math.floor(timeLeft / 60);
    let seconds = timeLeft % 60;
    seconds = seconds < 10 ? "0" + seconds : seconds;

    document.getElementById("timer").textContent =
      `Time: ${minutes}:${seconds}`;

    if (timeLeft <= 0) 
    {//beginning of if (timeLeft <= 0) 
      clearInterval(timerInterval);
      submitQuiz();
    }//end of if (timeLeft <= 0) 
        
  }, 1000);//end of timerInterval = setInterval(() => 
    
}//end of function startTimer() 

function loadQuestion() 
{//beginning of loadQuestion()
    
  const q = questions[currentQuestion];
  const quizDiv = document.getElementById("quiz");

  quizDiv.innerHTML = `
    <div class="question">
      <img src="${q.image}">
      <p>${currentQuestion + 1}. ${q.text}</p>
      <button id="trueBtn" onclick="answer(true)">True</button>
      <button id="falseBtn" onclick="answer(false)">False</button>
    </div>
  `;

  if (userAnswers[currentQuestion] !== null) 
  {//beginning of if (userAnswers[currentQuestion] !== null)
      
    if (userAnswers[currentQuestion]) 
    {//beginning of if (userAnswers[currentQuestion])
      document.getElementById("trueBtn").classList.add("selected");
    } //end of if (userAnswers[currentQuestion])
    else 
    {//beginning of else 
      document.getElementById("falseBtn").classList.add("selected");
    }//end of else
      
  }//end of if (userAnswers[currentQuestion] !== null)
    
}//end of loadQuestion()

function answer(value) 
{//beginning of function answer(value) 
    
  userAnswers[currentQuestion] = value;
  loadQuestion();
    
}//end of function answer(value) 

function nextQuestion() 
{//beginning of nextQuestion() 
    
  if (currentQuestion < questions.length - 1) 
  {//beginning of if (currentQuestion < questions.length - 1) 
    
    currentQuestion++;
    loadQuestion();
      
  }//end of if (currentQuestion < questions.length - 1) 
    
}//end of nextQuestion() 

function prevQuestion() 
{//beginning of function prevQuestion() 
    
  if (currentQuestion > 0) 
  {//beginning of if (currentQuestion > 0) 
      
    currentQuestion--;
    loadQuestion();
      
  }//end of if (currentQuestion > 0) 
    
}//end of function prevQuestion() 

function submitQuiz() 
{//beginning of function submitQuiz()
    
  if (quizSubmitted) return;
  quizSubmitted = true;

  clearInterval(timerInterval);

  let score = 0;
  let reviewHTML = "<h2>Review:</h2>";

  questions.forEach((q, i) => 
 {//beginning of questions.forEach((q, i) =>
          
    if (userAnswers[i] === q.answer) 
    {//beginning of if (userAnswers[i] === q.answer) 
      score++;
    }//end of  if (userAnswers[i] === q.answer) 
        
    else 
    {//beginning of else
      reviewHTML += `
        <div class="wrong">
          <p><strong>Question ${i + 1}:</strong> ${q.text}</p>
          <p>Your answer: ${userAnswers[i] === null ? "Not answered" : userAnswers[i]}</p>
          <p>Correct answer: ${q.answer}</p>
        </div>
      `;
    }//end of else
          
  });// end of questions.forEach((q, i) =>

  document.getElementById("quiz").style.display = "none";
  document.getElementById("navButtons").style.display = "none";
  document.getElementById("submitContainer").style.display = "none";

  document.getElementById("result").innerHTML =
    `You scored ${score} out of ${questions.length}`;

  document.getElementById("review").innerHTML = reviewHTML;

  document.getElementById("retryBtn").style.display = "inline-block";

  const body = document.body;
  body.insertBefore(document.getElementById("result"), body.children[1]);
  body.insertBefore(document.getElementById("retryBtn"), body.children[2]);
  body.insertBefore(document.getElementById("review"), body.children[3]);
    
}//end of function submitQuiz()

function retryQuiz() 
{//beginning of function retryQuiz() 
    
  currentQuestion = 0;
  userAnswers = new Array(questions.length).fill(null);
  timeLeft = 180;
  quizSubmitted = false;

  shuffleArray(questions);

  document.getElementById("quiz").style.display = "block";
  document.getElementById("navButtons").style.display = "block";
  document.getElementById("submitContainer").style.display = "block";

  document.getElementById("result").textContent = "";
  document.getElementById("review").innerHTML = "";
  document.getElementById("retryBtn").style.display = "none";
  document.getElementById("timer").textContent = "Time: 3:00";

  clearInterval(timerInterval);
  startTimer();
  loadQuestion();
    
}// end of function retryQuiz() 

// Start quiz
shuffleArray(questions);
loadQuestion();
startTimer();
