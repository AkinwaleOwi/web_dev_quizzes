function shuffleArray(array) 
{//beginning of function shuffleArray(array) 
    
  for (let i = array.length - 1; i > 0; i--) 
  {//beginning of for (let i = array.length - 1; i > 0; i--) 
      
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
      
  }//end of for (let i = array.length - 1; i > 0; i--) 
    
}//end of function shuffleArray(array) 

const questions = 
[//beginning of const questions = 
    
  {//beginning of q0
      
    text: "The Earth is flat.",
    answer: false,
    image: "pic_a.png"
  },//end of q0
    
  {//beginning of q1
    text: "JavaScript is a programming language.",
    answer: true,
    image: "pic_b.png"
  },//end of q1
    
  {//beginning of q2
    text: "The sun rises in the west.",
    answer: false,
    image: "pic_c.png"
  },//end of q2
    
  {//beginning of q3
    text: "Water boils at 100°C.",
    answer: true,
    image: "pic_d.png"
  },//end of q3
    
  {//beginning of q4
    text: "Humans can breathe underwater without equipment.",
    answer: false,
